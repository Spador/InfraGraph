# InfraGraph environment variables
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.
#
# Usage:
#   cp .env.example .env
#   docker compose up --build

# ── Neo4j ────────────────────────────────────────────────────────────
# URI used by the backend inside Docker Compose (service name = neo4j)
NEO4J_URI=bolt://neo4j:7687
# For local dev outside Docker, use: bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Backend ──────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production

# ── Seed data ────────────────────────────────────────────────────────
# Set to "true" to auto-populate the graph on first container start.
# Seeding is idempotent: skipped if the graph already has nodes.
SEED_ON_START=true
